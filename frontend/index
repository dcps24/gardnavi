<script>
window.addEventListener('scroll',()=>{document.getElementById('main-nav').style.padding=window.scrollY>50?'0.7rem 4rem':'1.2rem 4rem';});
async function checkAuth(){try{const r=await fetch('/.auth/me');const d=await r.json();if(d.clientPrincipal){document.getElementById('login-btn').style.display='none';document.getElementById('nav-user').style.display='flex';document.getElementById('user-name').textContent=d.clientPrincipal.userDetails;}}catch(e){}}
